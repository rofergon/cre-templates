{
  "name": "tokenized-asset-platform",
  "version": "1.0.0",
  "description": "Tokenized Asset Platform Protocol",
  "main": "index.js",
  "scripts": {
    "test": "hardhat test",
    "compile": "hardhat compile",
    "ace:setup-policy": "hardhat run scripts/setup_ace_policy.cjs --network sepolia",
    "deploy:equity:new": "hardhat run scripts/deploy_equity_new.cjs --network sepolia",
    "deploy:equity:new:test-mode": "cross-env TEST_MODE_FORWARDER_BYPASS=true AUTO_UPDATE_CRE_CONFIGS=true AUTO_UPDATE_DOTENV=true hardhat run scripts/deploy_equity_new.cjs --network sepolia",
    "verify:equity:latest": "hardhat run scripts/verify_equity_latest.cjs --network sepolia",
    "deploy:equity:new:verify": "npm run deploy:equity:new && npm run verify:equity:latest",
    "deploy:equity:new:test-mode:verify": "npm run deploy:equity:new:test-mode && npm run verify:equity:latest"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^2.3.0",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-verify": "^2.1.1",
    "@openzeppelin/contracts": "^4.9.3",
    "@openzeppelin/contracts-upgradeable": "^4.9.6",
    "dotenv": "^17.3.1",
    "js-yaml": "^4.1.1",
    "viem": "^2.44.4"
  }
}
